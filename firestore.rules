// FILE LOCATION: firestore.rules
// CHANGE: Added notifications collection rules.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Pantry Items ───────────────────────────────────────────────────────
    match /pantry_items/{itemId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.giverId == request.auth.uid;

      allow update: if request.auth != null && (
        resource.data.giverId == request.auth.uid
        || (
          resource.data.status == 'available'
          && request.resource.data.claimerId == request.auth.uid
          && request.resource.data.status == 'reserved'
        )
        || (
          resource.data.claimerId == request.auth.uid
          && request.resource.data.status == 'available'
        )
        || (
          resource.data.claimerId == request.auth.uid
          && resource.data.status == 'reserved'
          && request.resource.data.status == 'completed'
        )
      );

      allow delete: if request.auth != null
        && resource.data.giverId == request.auth.uid;
    }

    // ── Conversations ──────────────────────────────────────────────────────
    match /conversations/{convId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;

      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;

      allow delete: if request.auth != null
        && request.auth.uid in resource.data.participants;

      match /messages/{msgId} {
        allow read: if request.auth != null
          && request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convId))
              .data.participants;

        allow create: if request.auth != null
          && request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convId))
              .data.participants
          && request.resource.data.senderId == request.auth.uid;
      }
    }

    // ── Notifications ──────────────────────────────────────────────────────
    // Any authenticated user can create a notification (the server/app writes
    // on behalf of other users — e.g. notifying all matching users).
    // Only the recipient can read, update (mark read), or delete their own.
    match /notifications/{notifId} {
      allow read, update, delete: if request.auth != null
        && resource.data.recipientId == request.auth.uid;

      allow create: if request.auth != null;
    }
  }
}
